# ============================================
# iso18091-gobierno — Variables de entorno
# Firebase project: gobiernos-locales-iso (BASE DE DATOS PROPIA)
# Copiar a .env.local y completar valores reales
# ============================================

# ── Firebase Admin SDK ────────────────────────────────────────
# Generar en: https://console.firebase.google.com/project/gobiernos-locales-iso/settings/serviceaccounts/adminsdk
# ⚠️  NUNCA commitear el JSON descargado — solo copiar los valores aquí
FIREBASE_PROJECT_ID=gobiernos-locales-iso
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@gobiernos-locales-iso.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_NEW_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=gobiernos-locales-iso.appspot.com

# ── Firebase Client SDK (frontend) ────────────────────────────
# Obtener en: https://console.firebase.google.com/project/gobiernos-locales-iso/settings/general → Agregar app web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gobiernos-locales-iso.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gobiernos-locales-iso
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gobiernos-locales-iso.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Edición hardcodeada — NO cambiar ──────────────────────────
NEXT_PUBLIC_EDITION=government
NEXT_PUBLIC_APP_URL=https://iso18091-gobierno.vercel.app

# ── IA ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Seguridad y performance ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
ENABLE_STRUCTURED_LOGGING=true

# ── Features ──────────────────────────────────────────────────
NEXT_PUBLIC_USE_DYNAMIC_NAV=true
ENABLE_UNIFIED_AI_CHAT_CORE=true
NODE_ENV=production
