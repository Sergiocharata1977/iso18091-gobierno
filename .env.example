# Firebase Admin SDK Configuration
# These credentials are used for server-side operations with Firebase Admin SDK
# IMPORTANT: Never commit the actual .env file with real credentials to version control

# Firebase Project ID
# Find this in Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your-project-id

# Firebase Service Account Email
# Find this in Firebase Console > Project Settings > Service Accounts
# Format: firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Firebase Private Key
# Find this in Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# IMPORTANT: Keep the quotes and replace \n with actual newlines or use \\n
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage Bucket
# Find this in Firebase Console > Storage
# Format: your-project.appspot.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Client SDK Configuration (for frontend)
# These are public and safe to expose in the browser

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Application Configuration

# Node environment (development, staging, production)
NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEALER_PUBLIC_ORGANIZATION_ID=
NEXT_PUBLIC_DEALER_PUBLIC_ORGANIZATION_ID=

# Rate Limiting Configuration

# Time window for rate limiting in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum number of requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Enable structured logging (JSON format)
ENABLE_STRUCTURED_LOGGING=true

# Optional: External Services

# Resend API Key (for email sending from contact forms)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Meta WhatsApp App Secret used to validate X-Hub-Signature-256 on webhooks
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Billing / Mobbex
# Fuente de verdad objetivo: organizations/{orgId}/meta/billing
# Durante la migracion, estos secretos siguen siendo globales pero el checkout
# y el webhook deben resolverse contra la organizacion efectiva, no contra userId.
MOBBEX_API_KEY=
MOBBEX_ACCESS_TOKEN=
MOBBEX_WEBHOOK_SECRET=
MOBBEX_TEST_MODE=true

# Contact email (where form submissions will be sent)
CONTACT_EMAIL=your-email@gmail.com

# SendGrid API Key (for email notifications)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Sentry DSN (for error tracking)
# SENTRY_DSN=your-sentry-dsn

# Redis URL (for caching)
# REDIS_URL=redis://localhost:6379

# ============================================
# AI CORE — Feature Flags (Olas 1-4)
# ============================================

# Activar el core unificado de IA para el canal de chat.
# Cuando está activo, /api/chat/messages usa ChatAdapter → UnifiedAIOperator.
# En false, sigue el pipeline legacy y only mirrors al core como compatibilidad.
ENABLE_UNIFIED_AI_CHAT_CORE=false

# Activar navegacion dinamica basada en installed_capabilities.
# En staging/preview se habilita automaticamente si no se define este flag.
NEXT_PUBLIC_USE_DYNAMIC_NAV=true



# ============================================
# HOW TO GET FIREBASE ADMIN SDK CREDENTIALS
# ============================================
#
# 1. Go to Firebase Console: https://console.firebase.google.com/
# 2. Select your project
# 3. Click on the gear icon (⚙️) next to "Project Overview"
# 4. Go to "Project Settings"
# 5. Navigate to the "Service Accounts" tab
# 6. Click "Generate New Private Key"
# 7. A JSON file will be downloaded with the following structure:
#    {
#      "type": "service_account",
#      "project_id": "your-project-id",
#      "private_key_id": "...",
#      "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
#      "client_email": "firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com",
#      "client_id": "...",
#      "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#      "token_uri": "https://oauth2.googleapis.com/token",
#      "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
#      "client_x509_cert_url": "..."
#    }
#
# 8. Copy the values to your .env.local file:
#    - project_id → FIREBASE_PROJECT_ID
#    - client_email → FIREBASE_CLIENT_EMAIL
#    - private_key → FIREBASE_PRIVATE_KEY (keep the \n characters or replace with actual newlines)
#
# 9. For FIREBASE_STORAGE_BUCKET, go to Storage in Firebase Console and copy the bucket name
#
# ============================================
# APP CLIENTE — AGROBICIUFA
# ============================================
#
# URL de descarga del APK para la página /app-cliente/instalar
# Opciones recomendadas:
#   - GitHub Releases: https://github.com/Sergiocharata1977/9001app-v8/releases/download/vX.X-cliente/AgroBiciufa-Cliente-vX.apk
#   - Google Drive (enlace directo de descarga)
#
# Cómo generar el APK:
#   bash scripts/build-cliente-apk.sh
#
# Cómo subir a GitHub Releases:
#   gh release create v1.0-cliente android/app/build/outputs/apk/release/AgroBiciufa-Cliente-v1.apk
#
NEXT_PUBLIC_CLIENTE_APK_URL=

# Número WhatsApp de contacto Agrobiciufa (formato internacional sin +)
# Ej: 5493564XXXXXX  (54 = Argentina, 9 = celular, luego el número)
NEXT_PUBLIC_AGROBICIUFA_WHATSAPP=5493564XXXXXX

# ============================================
# SECURITY NOTES
# ============================================
#
# - NEVER commit .env.local or .env with real credentials to Git
# - Add .env.local to .gitignore
# - Use different service accounts for development, staging, and production
# - Rotate credentials regularly
# - Limit service account permissions to only what's needed
# - Store production credentials in secure environment variable managers (Vercel, AWS Secrets Manager, etc.)
#

# ── ElevenLabs Voice + WhatsApp Agent ────────────────────────────────────────
# API Key de ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# Requerida para TTS, Conversational AI y vinculación de agentes WhatsApp
ELEVENLABS_API_KEY=sk_...
# Voice ID del asistente Don Cándido (crear en ElevenLabs Voice Lab o usar el existente)
ELEVENLABS_VOICE_ID=kulszILr6ees0ArU8miO
# Agent ID del agente Don Cándido (obtenido en https://elevenlabs.io/app/conversational-ai)
# IMPORTANTE: usar número WhatsApp SEPARADO del webhook propio multi-tenant
ELEVENLABS_AGENT_ID_DON_CANDIDO=agent_...
# Phone Number ID de WhatsApp Business vinculado al agente ElevenLabs
# (≠ del número usado por el webhook /api/public/whatsapp/webhook)
# Es un ID de Meta, no el número E.164 del teléfono
# Obtener en: Meta Business Suite → WhatsApp → Configuración de teléfono
ELEVENLABS_WHATSAPP_PHONE_NUMBER_ID=1234567890123456
